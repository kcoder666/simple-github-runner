# Copy to .env and fill in your values. Do NOT commit .env.
# .env is git-ignored; this template is safe to commit.

# Personal Access Token (or GitHub App token) used to mint short-lived
# registration tokens at container startup. Required because ephemeral runners
# re-register on every restart and a static token is single-use.
#   - Repo runners: fine-grained PAT with "Administration" repo permission (read/write)
#   - Org runners:  PAT with the "manage_runners:org" scope
#   - Both:         a PAT that covers both
GITHUB_PAT=<github-pat>

# --- Org-wide runners (profile: org) ---
# Serves every repo in the org. Start with:
#   docker compose --profile org up -d --scale org-runner=3
ORG_URL=https://github.com/<org>

# --- Per-repo runners (profile: repos) ---
# One runner per repo (repos may live under different owners). Start with:
#   docker compose --profile repos up -d
# Add more by copying a repo-* service in docker-compose.yml + a REPO_URL_n here.
REPO_URL_1=https://github.com/<owner>/<repo_a>
REPO_URL_2=https://github.com/<owner>/<repo_b>
