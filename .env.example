# Copy to .env and fill in your values. Do NOT commit .env.
# .env is git-ignored; this template is safe to commit.

# Full URL of the repo or org to attach the runner to
REPO_URL=https://github.com/<username>/<repo_name>

# Personal Access Token (or GitHub App token) used to mint short-lived
# registration tokens at container startup. Required because ephemeral runners
# re-register on every restart and a static token is single-use.
#   - Repo runner:  fine-grained PAT with "Administration" repo permission (read/write)
#   - Org runner:   PAT with the "manage_runners:org" scope
GITHUB_PAT=<github-pat>
